# Use the public npm registry for Font Awesome free packages (CI has no Font Awesome Pro token).
@fortawesome:registry=https://registry.npmjs.org/

# Defensively clear any auth header for the public registry. Netlify's build
# image injects `_authToken=${NPM_TOKEN}` when NPM_TOKEN is set on the site;
# an empty/stale value causes npm to send `Authorization: Bearer ` and get
# back E401 "Incorrect or missing password" for public packages.
//registry.npmjs.org/:_authToken=
//registry.npmjs.org/:always-auth=false
